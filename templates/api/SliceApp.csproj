<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <RootNamespace>SliceApp</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Slice.AspNetCore" Version="SLICE_VERSION" />
    <PackageReference Include="Slice.Application" Version="SLICE_VERSION" />
    <PackageReference Include="Slice.Domain" Version="SLICE_VERSION" />
    <PackageReference Include="Slice.Mediator.Default" Version="SLICE_VERSION" />
    <PackageReference Include="Slice.Modularity" Version="SLICE_VERSION" />
    <PackageReference Include="Slice.EventBus" Version="SLICE_VERSION" />
    <PackageReference Include="Slice.EntityFrameworkCore" Version="SLICE_VERSION" />
    <PackageReference Include="Slice.MultiTenancy" Version="SLICE_VERSION" />
    <PackageReference Include="Slice.Authorization" Version="SLICE_VERSION" />
    <PackageReference Include="Slice.Authentication" Version="SLICE_VERSION" />
    <PackageReference Include="Slice.Settings" Version="SLICE_VERSION" />
    <PackageReference Include="Slice.Localization" Version="SLICE_VERSION" />
    <PackageReference Include="Slice.Management" Version="SLICE_VERSION" />
    <PackageReference Include="Slice.ApiVersioning" Version="SLICE_VERSION" />
    <!--#if (Postgres) -->
    <PackageReference Include="Slice.EntityFrameworkCore.PostgreSQL" Version="SLICE_VERSION" />
    <PackageReference Include="Slice.PostgresStack" Version="SLICE_VERSION" />
    <PackageReference Include="Npgsql" Version="10.0.3" />
    <!--#else -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="10.0.0" />
    <!--#endif -->
  </ItemGroup>

</Project>
