<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
  </PropertyGroup>

  <ItemGroup>
    <!-- The serving app's shared framework (Generic Host + the ASP.NET types TenantModule pulls in). -->
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <!-- Real cross-process lock for the single-runner migration guard (opt-in via ConnectionStrings:Redis). -->
    <PackageReference Include="Slice.DistributedLocking.Redis" Version="SLICE_VERSION" />
  </ItemGroup>

  <ItemGroup>
    <!-- Reuse the API's TenantModule / TenantDbContext so this job composes the identical module graph. -->
    <ProjectReference Include="..\TenantApp.csproj" />
  </ItemGroup>

</Project>
